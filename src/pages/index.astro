---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/shared/Header';
import HubStats from '../components/hub/HubStats';
import MapCard from '../components/hub/MapCard';
import { MAPS } from '../lib/constants';
---

<BaseLayout title="Hub">
  <div class="min-h-screen flex flex-col">
    <Header client:load currentPage="/" />

    <main class="flex-1 flex flex-col px-8 md:px-12">
      <div class="w-full max-w-[860px] mx-auto py-12 md:py-14">

        {/* Hero */}
        <div class="text-center mb-11" style="animation: fadeUp 0.55s ease both">
          <h1 class="font-heading text-[26px] font-semibold text-[var(--text-primary)] mb-2.5 leading-[1.35] tracking-[-0.01em]">
            Explore a cobertura de <span class="text-[var(--accent)]">mídia</span> no Brasil
          </h1>
          <p class="text-[14px] text-[var(--text-muted)] leading-[1.65] max-w-[440px] mx-auto">
            Mapas interativos com dados da Anatel. Filtre estações, estime audiências e monte planos de mídia.
          </p>

          {/* Status */}
          <div class="flex items-center justify-center gap-2 mt-5" style="animation: fadeUp 0.55s ease 0.08s both">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-green-400)] animate-[dotPulse_2.5s_ease_infinite]"></span>
            <span class="text-[12px] text-[var(--text-muted)]">Dados atualizados — Abril 2026</span>
          </div>
        </div>

        {/* Stats */}
        <div>
          <HubStats client:visible />
        </div>

        {/* Divider — subtle horizontal line fading at the edges, purely
            decorative. max-width matches the map card grid below so it
            reads as anchoring that block rather than spanning the page. */}
        <div
          class="max-w-[580px] mx-auto my-9 h-px"
          aria-hidden="true"
          style="background: linear-gradient(to right, transparent, var(--border), transparent); animation: fadeIn 0.7s ease 0.2s both"
        ></div>

        {/* Map cards */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5 max-w-[580px] mx-auto">
          {Object.values(MAPS).filter(map => map.status === 'active').map((map, i) => (
            <div style={`animation: fadeUp 0.5s ease ${0.22 + i * 0.05}s both`}>
              <MapCard
                name={map.name}
                subtitle={map.subtitle}
                description={map.description}
                icon={map.icon}
                href={map.href}
                status={map.status}
                stats={map.stats}
              />
            </div>
          ))}
        </div>

        {/* Footer */}
        <footer class="mt-10 text-[11px] text-[var(--text-muted)] text-center" style="animation: fadeIn 0.5s ease 0.4s both">
          Dados públicos Anatel · Uso interno HYPR
        </footer>
      </div>
    </main>
  </div>
</BaseLayout>
