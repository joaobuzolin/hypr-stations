---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/shared/Header';
---

<BaseLayout title="Radio Map" description="Mapa interativo de estações FM e AM do Brasil" fullscreen>
  <div class="h-screen flex flex-col">
    <Header client:load currentPage="/radio" />

    <main class="flex-1 flex items-center justify-center">
      <div class="text-center px-6">
        <div class="w-16 h-16 rounded-2xl bg-[var(--accent-muted)] text-[var(--accent)]
                    flex items-center justify-center mx-auto mb-6">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9" />
            <path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4" />
            <circle cx="12" cy="12" r="2" />
            <path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4" />
            <path d="M19.1 4.9C23 8.8 23 15.1 19.1 19" />
          </svg>
        </div>
        <h1 class="font-heading text-2xl font-bold text-[var(--text-primary)] mb-2">
          Radio Map
        </h1>
        <p class="text-sm text-[var(--text-secondary)] mb-6">
          Migração do mapa de rádio em andamento.
          <br />Será implementado na Fase 3.
        </p>
        <a href="/"
           class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium
                  bg-[var(--bg-surface2)] text-[var(--text-secondary)] border border-[var(--border)]
                  hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
          </svg>
          Voltar ao Hub
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
